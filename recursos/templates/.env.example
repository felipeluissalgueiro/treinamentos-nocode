# Exemplo de .env — copie para .env e preencha com seus valores reais
# NUNCA comite o .env (já está no .gitignore)

# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-xxxx
OPENAI_API_KEY=sk-xxxx
# Opcional — modelos baratos via agregador:
# OPENROUTER_API_KEY=sk-or-xxxx

# --- Database ---
# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyxxxx
SUPABASE_SERVICE_ROLE_KEY=eyxxxx

# Ou Postgres local
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# --- Deploy ---
# Vercel
VERCEL_TOKEN=xxxx

# Railway
RAILWAY_TOKEN=xxxx

# --- Integrações comuns ---
# GitHub
GITHUB_TOKEN=ghp_xxxx

# Slack (opcional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/xxxx

# Email (Resend)
# RESEND_API_KEY=re_xxxx

# WhatsApp (Z-API, Evo etc — escolher 1)
# ZAPI_INSTANCE=xxxx
# ZAPI_TOKEN=xxxx

# --- Config do projeto ---
NODE_ENV=development
LOG_LEVEL=info
PORT=8000
